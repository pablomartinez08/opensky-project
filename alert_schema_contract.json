{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlightAlert",
  "description": "Contrato unico del topic Kafka 'flight-alerts'. Construido ESTRICTAMENTE con datos procedentes del API de OpenSky (/states/all) y computaciones de Flink, sin dependencias externas.",
  "version": "1.1.0",

  "_campos_comunes": "Presentes SIEMPRE en todas las alertas (nativos del API / calculados en stream)",
  "common_fields": {
    "tipo_alerta":  "string  — Enum: 'vertical' | 'alta_densidad' | 'zona_muerta' | 'cep_aterrizaje_emergencia'",
    "estado":       "string  — Enum: 'inicio' | 'actualizacion' | 'fin' (Ciclo de vida de la alerta)",
    "severidad":    "string  — Enum: 'baja' | 'media' | 'alta' | 'critica'",
    "timestamp":    "string  — ISO 8601 (ej: '2026-03-24T18:30:12Z')",
    "latitud":      "number  — Coordenada del evento (o del centro de la celda H3)",
    "longitud":     "number  — Coordenada del evento (o del centro de la celda H3)",
    "origen_pais":  "string | null — Pais de origen de la aeronave o null si es alerta de zona (API: origin_country)",
    "en_tierra":    "boolean | null — Si la aeronave esta en superficie o null si es alerta de zona (API: on_ground)"
  },

  "_campos_opcionales": "Presentes SOLO segun el tipo_alerta",
  "optional_fields": {
    "icao24":                  "string | null  — Identificador ICAO de la aeronave (vertical, cep)",
    "callsign":                "string | null  — Indicativo de vuelo (vertical, cep)",
    "altitud_actual":          "number | null  — Metros (vertical)",
    "altitud_previa":          "number | null  — Metros (vertical)",
    "delta_altitud":           "number | null  — Metros, negativo = descenso (vertical)",
    "velocidad_vertical_ms":   "number | null  — m/s (API: vertical_rate) (vertical)",
    "velocidad_kmh":           "number | null  — km/h (calculado desde API: velocity) (vertical, cep)",
    "heading":                 "number | null  — Grados (API: true_track) (vertical, cep)",
    "celda_h3":                "string | null  — Indice H3 (alta_densidad, zona_muerta)",
    "num_vuelos_actual":       "number | null  — Cantidad en ventana de Flink (alta_densidad, zona_muerta)",
    "num_vuelos_previo":       "number | null  — Cantidad en la ventana anterior de Flink (zona_muerta)",
    "vuelos_afectados":        "array  | null  — Lista de callsigns (alta_densidad)",
    "ventana_inicio":          "string | null  — ISO 8601 (alta_densidad, zona_muerta)",
    "ventana_fin":             "string | null  — ISO 8601 (alta_densidad, zona_muerta)",
    "patron":                  "string | null  — Descripcion del patron CEP (cep)",
    "altitud_inicio_patron":   "number | null  — Metros (cep)",
    "altitud_final":           "number | null  — Metros (cep)",
    "duracion_vel_cero_seg":   "number | null  — Segundos (cep)"
  },

  "examples": [
    {
      "_comment": "TIPO 1 — Alerta Vertical (ascenso/descenso brusco)",
      "tipo_alerta": "vertical",
      "estado": "inicio",
      "severidad": "alta",
      "timestamp": "2026-03-24T18:30:12Z",
      "latitud": 48.3456,
      "longitud": 11.7890,
      "origen_pais": "Germany",
      "en_tierra": false,
